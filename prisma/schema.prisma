generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String   // pdf, docx, txt, md, url
  content     String
  chunks      Int      @default(0)
  status      String   @default("processing") // processing, ready, error
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("documents")
}

model Conversation {
  id          String    @id @default(cuid())
  sessionId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // user, assistant
  content        String
  sources        String?      // JSON array of source documents
  feedback       String?      // positive, negative, null
  createdAt      DateTime     @default(now())

  @@map("messages")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model UnansweredQuestion {
  id        String   @id @default(cuid())
  question  String
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("unanswered_questions")
}

model RateLimit {
  key         String   @id // ex.: "chat:<ip>" ou "login:<ip>"
  windowStart DateTime
  count       Int      @default(0)

  @@map("rate_limits")
}
