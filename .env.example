# ============================================
# LibertyBot - Variáveis de Ambiente (exemplo)
# Copie para .env.local e preencha os valores.
# ============================================

# --- Database ---
# Dev local: SQLite | Produção (Neon): connection string POOLED com ?sslmode=require
DATABASE_URL="file:./dev.db"
# Produção (Neon): connection string DIRECT (usada só por prisma migrate)
# DIRECT_URL="postgresql://usuario:senha@ep-xxx.sa-east-1.aws.neon.tech/libertybot?sslmode=require"

# --- IA (NVIDIA - API compatível OpenAI) ---
# Gere em https://build.nvidia.com
OPENAI_API_KEY="nvapi-..."

# --- Qdrant Vector Database ---
# Dev local: docker run -p 6333:6333 qdrant/qdrant | Produção: URL do cluster Qdrant Cloud
QDRANT_URL="http://localhost:6333"
# QDRANT_API_KEY=""   # obrigatório no Qdrant Cloud
QDRANT_COLLECTION="liberty_knowledge"

# --- Autenticação Admin ---
# Senha de acesso ao /dashboard, /knowledge e /settings
ADMIN_PASSWORD="troque-por-uma-senha-forte"
# Segredo para assinar o cookie de sessão (32+ bytes): openssl rand -base64 32
AUTH_SECRET=""

# --- App ---
NEXT_PUBLIC_APP_NAME="LibertyBot"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
